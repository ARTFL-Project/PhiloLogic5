{
    "name": "philologic",
    "version": "5.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "serve": "npm i && vite preview",
        "build": "npm i && vite build && rm -rf node_modules",
        "host": "npm i && vite --host",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@intlify/unplugin-vue-i18n": "^6.0.8",
        "@popperjs/core": "^2.9.2",
        "axios": "^1.7.0",
        "bootstrap": "^5.3.0",
        "bootstrap-icons": "^1.13.1",
        "chart.js": "^4.4.9",
        "core-js": "^3.13.1",
        "dompurify": "^3.1.7",
        "glightbox": "^3.2.0",
        "gsap": "^3.12.0",
        "pinia": "^2.2.0",
        "unplugin": "^2.3.6",
        "vue": "^3.5.0",
        "vue-chartjs": "^5.3.2",
        "vue-i18n": "^11.0.0",
        "vue-router": "^4.4.0",
        "vue-scrollto": "^2.17.1"
    },
    "devDependencies": {
        "@originjs/vite-plugin-commonjs": "^1.0.3",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/compiler-sfc": "^3.1.0",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^7.5.0",
        "eslint-plugin-vue": "^8.5.0",
        "jsdom": "^29.0.2",
        "sass": "^1.80.0",
        "vite": "^7.1.2",
        "vite-plugin-compression2": "^2.2.0",
        "vitest": "^4.1.4"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "eslint:recommended"
        ],
        "globals": {
            "defineProps": "readonly",
            "defineEmits": "readonly",
            "defineExpose": "readonly",
            "defineOptions": "readonly"
        },
        "rules": {
            "no-console": "off",
            "vue/multi-word-component-names": "off",
            "vue/no-multiple-template-root": "off"
        },
        "parserOptions": {
            "ecmaVersion": 12,
            "sourceType": "module"
        }
    },
    "browserslist": [
        "> 0.5%, last 2 versions, not dead, not IE 11"
    ]
}
